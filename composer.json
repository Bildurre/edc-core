{
    "name": "bgm/core",
    "description": "Boardgame Motor \u2014 n\u00facleo backend (Laravel) reutilizable",
    "type": "library",
    "license": "proprietary",
    "version": "0.0.1",
    "require": {
        "php": "^8.2",
        "laravel/sanctum": "^4.0",
        "spatie/laravel-permission": "^8.0",
        "spatie/laravel-translatable": "^6.0",
        "spatie/laravel-sluggable": "^4.0",
        "spatie/laravel-medialibrary": "^11.0",
        "spatie/browsershot": "^5.0",
        "barryvdh/laravel-dompdf": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Bgm\\Core\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Bgm\\Core\\MotorServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
