{
    "name": "bgm/core",
    "description": "Boardgame Motor — núcleo backend (Laravel) reutilizable",
    "type": "library",
    "license": "proprietary",
    "version": "0.0.1",
    "require": {
        "php": "^8.2"
    },
    "autoload": {
        "psr-4": {
            "Bgm\\Core\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Bgm\\Core\\MotorServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
