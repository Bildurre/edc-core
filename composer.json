{
    "name": "edc-motor/core",
    "description": "EdC Motor (Espadas de Ceniza Motor) — núcleo backend Laravel reutilizable para webs de juegos de mesa: auth y roles, contenido i18n, render a PNG, PDF recortables, CRM de páginas, configuración, usuarios y backup",
    "type": "library",
    "keywords": [
        "laravel",
        "boardgame",
        "edc-motor"
    ],
    "homepage": "https://github.com/bildurre/boardgame_motor",
    "license": "GPL-3.0-only",
    "version": "0.2.0",
    "support": {
        "issues": "https://github.com/bildurre/boardgame_motor/issues",
        "source": "https://github.com/bildurre/edc-core"
    },
    "require": {
        "php": "^8.2",
        "laravel/sanctum": "^4.0",
        "spatie/laravel-permission": "^8.0",
        "spatie/laravel-translatable": "^6.0",
        "spatie/laravel-sluggable": "^4.0",
        "spatie/laravel-medialibrary": "^11.0",
        "spatie/browsershot": "^5.0",
        "barryvdh/laravel-dompdf": "^3.0",
        "spatie/laravel-backup": "^10.3"
    },
    "autoload": {
        "psr-4": {
            "Edc\\Core\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Edc\\Core\\MotorServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
